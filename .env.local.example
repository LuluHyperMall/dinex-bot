# Copy this file to .env.local and fill in your values.

# Database (SQLite for MVP)
DATABASE_URL="file:./dev.db"

# OpenAI — required for real GPT-4o reasoning + Realtime voice.
# Without it, the bot falls back to browser speech + a local deterministic engine.
OPENAI_API_KEY=""

# Model used for Raj's tool-calling reasoning
OPENAI_MODEL="gpt-4o"

# OpenAI Realtime voice model (used to mint ephemeral session tokens)
OPENAI_REALTIME_MODEL="gpt-4o-realtime-preview"

# Server
PORT="3000"

# Public base URL (used in QR codes / email links)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
